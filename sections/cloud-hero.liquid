<section class="cp-hero">
  <picture>
    <source
      media="(max-width: 749px)"
      srcset="{{ 'hero-image-mobile.png' | asset_url }}"
    >
    <img
      class="cp-hero__img"
      src="{{ 'hero-image.png' | asset_url }}"
      alt="The Cloud Pillow — Great sleep in every position"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    >
  </picture>
  <div class="cp-hero__overlay">
    <div class="cp-hero__content">
      <p class="cp-hero__eyebrow">Introducing The Cloud™ Pillow</p>
      <h1 class="cp-hero__heading">
        Sleep Better.<br>
        Wake Up <em>Refreshed.</em>
      </h1>
      <p class="cp-hero__sub">
        The only pillow engineered with 6-zone contoured support for every sleep position — backed by chiropractors.
      </p>
      <div>
        <a href="#products" class="cp-hero__cta">Shop Now</a>
        <a href="#about" class="cp-hero__cta-secondary">Learn More</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cloud Hero",
  "tag": "div",
  "settings": []
}
{% endschema %}
