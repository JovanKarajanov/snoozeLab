{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .fyr-badge {
    position: absolute;
    top: var(--spacing-2, 0.8rem);
    left: var(--spacing-2, 0.8rem);
    z-index: 2;
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.5rem 0.9rem;
    border-radius: 4rem;
    pointer-events: none;
  }

  .fyr-card-wrap {
    position: relative;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient" id="products">
  <div class="collection section-{{ section.id }}-padding page-width">

    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="collection__title title-wrapper title-wrapper--no-top-margin">
        {%- if section.settings.heading != blank -%}
          <h2 class="title inline-richtext h1{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="subtitle{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--2-col-desktop grid--1-col-tablet-down"
      role="list"
    >
      {%- assign skip_styles = false -%}
      {%- for i in (1..4) -%}
        {%- liquid
          case i
            when 1
              assign product = section.settings.product_1
              assign badge   = section.settings.badge_1
            when 2
              assign product = section.settings.product_2
              assign badge   = section.settings.badge_2
            when 3
              assign product = section.settings.product_3
              assign badge   = section.settings.badge_3
            when 4
              assign product = section.settings.product_4
              assign badge   = section.settings.badge_4
          endcase
        -%}

        {%- if product != blank -%}
          <li
            class="grid__item fyr-card-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- if badge != blank -%}
              <span class="fyr-badge">{{ badge | escape }}</span>
            {%- endif -%}

            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_secondary_image: false,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_styles,
              section_id: section.id,
              quick_add: false
            %}

            {%- assign skip_styles = true -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Find Your Relief",
  "tag": "div",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Relief"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Choose the product that's right for you."
    },
    {
      "type": "header",
      "content": "Product 1"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge text (product 1)"
    },
    {
      "type": "header",
      "content": "Product 2"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge text (product 2)"
    },
    {
      "type": "header",
      "content": "Product 3"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge text (product 3)"
    },
    {
      "type": "header",
      "content": "Product 4"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "text",
      "id": "badge_4",
      "label": "Badge text (product 4)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt",    "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square",   "label": "Square" }
      ],
      "default": "adapt"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ]
}
{% endschema %}
