<section class="cp-section cp-section--lavender" id="about">
  <div class="cp-container">

    <div class="cp-section-header">
      <span class="cp-eyebrow">Engineered for Sleep</span>
      <h2 class="cp-heading">What Makes The Cloud™ Different</h2>
      <p class="cp-subheading">
        Most pillows are built for one type of sleeper. The Cloud™ was built for all of them.
      </p>
    </div>

    <!-- Feature 1: Sleep positions -->
    <div class="cp-about__feature">
      <img
        class="cp-about__img"
        src="{{ 'pillow-sleep-positions.webp' | asset_url }}"
        alt="Great sleep in every position"
        width="600"
        height="600"
        loading="lazy"
      >
      <div class="cp-about__text-block">
        <span class="cp-eyebrow">Versatile by design</span>
        <h3 class="cp-about__title">Great Sleep In Every Position</h3>
        <p class="cp-about__desc">
          Whether you sleep on your back, side, stomach, or switch throughout the night — The Cloud™ adapts. Its contoured memory foam core cradles your head in perfect alignment no matter how you sleep.
        </p>
        <ul class="cp-about__specs">
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Ergonomically shaped for back, side &amp; stomach sleepers
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Contoured zones maintain spinal alignment all night
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            No more waking up to flip or adjust your pillow
          </li>
        </ul>
      </div>
    </div>

    <hr class="cp-divider" style="margin: 0 0 80px;">

    <!-- Feature 2: Special features -->
    <div class="cp-about__feature cp-about__feature--reverse">
      <img
        class="cp-about__img"
        src="{{ 'pillow-special-features.webp' | asset_url }}"
        alt="What makes The Cloud Pillow special"
        width="600"
        height="600"
        loading="lazy"
      >
      <div class="cp-about__text-block">
        <span class="cp-eyebrow">Premium materials</span>
        <h3 class="cp-about__title">What Makes The Cloud™ Special</h3>
        <p class="cp-about__desc">
          Four clinically-validated properties in a single pillow. The Cloud™ combines cooling technology, adjustable height, and medical-grade materials to deliver the best night's sleep of your life.
        </p>
        <ul class="cp-about__specs">
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <strong>Stays Cool All Night</strong> — open-cell foam and cooling gel cover
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <strong>Adjustable Height</strong> — remove or add fill to fit your preference
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <strong>Chiropractor Approved</strong> — endorsed by spinal alignment professionals
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <strong>Hypoallergenic &amp; Antibacterial</strong> — safe for sensitive sleepers
          </li>
        </ul>
      </div>
    </div>

    <hr class="cp-divider" style="margin: 0 0 80px;">

    <!-- Feature 3: 6-zone support details -->
    <div class="cp-about__feature">
      <img
        class="cp-about__img"
        src="{{ 'pillow-with-details.webp' | asset_url }}"
        alt="6-zone support for total sleep comfort"
        width="600"
        height="600"
        loading="lazy"
      >
      <div class="cp-about__text-block">
        <span class="cp-eyebrow">Precision engineering</span>
        <h3 class="cp-about__title">6-Zone Support for Total Sleep Comfort</h3>
        <p class="cp-about__desc">
          Unlike a flat foam block, The Cloud™ is sculpted into 6 distinct support zones — each designed for a specific part of your head, neck, and shoulders. The result? Zero pressure points, zero neck pain.
        </p>
        <ul class="cp-about__specs">
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><text x="12" y="16" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">1</text></svg>
            Back sleeper cradle — supports natural head positioning
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><text x="12" y="16" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">2</text></svg>
            Side sleeper wings — relieve pressure and improve alignment
          </li>
          <li class="cp-about__spec-item">
            <svg class="cp-about__spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><text x="12" y="16" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">3</text></svg>
            Contoured zones — head, neck, shoulders &amp; arms
          </li>
        </ul>
      </div>
    </div>

  </div>
</section>

<!-- Awards / Licences bar -->
<div class="cp-licences">
  <div class="cp-container">
    <span class="cp-eyebrow">Recognised by experts worldwide</span>
    <img
      class="cp-licences__img"
      src="{{ 'pillow-with-licences.png' | asset_url }}"
      alt="Top Rated Pillow, Innovation in Sleep Award, Chiropractor Approved, Best Pillow 2025"
      width="1024"
      height="934"
      loading="lazy"
    >
  </div>
</div>

{% schema %}
{
  "name": "Cloud About",
  "tag": "div",
  "settings": []
}
{% endschema %}
