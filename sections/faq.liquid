<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&display=swap"
  media="print"
  onload="this.media='all'"
>
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&display=swap">
</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .faq-{{ section.id }} {
    max-width: 136rem;
    margin: 0 auto;
  }

  .faq-{{ section.id }} .faq__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 3.6rem;
    letter-spacing: 0.01em;
    text-align: center;
    margin: 0 0 5rem;
  }

  .faq-{{ section.id }} .faq__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 6rem;
  }

  @media screen and (max-width: 749px) {
    .faq-{{ section.id }} .faq__columns {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  .faq-{{ section.id }} .faq__item {
    border: none;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }

  .faq-{{ section.id }} .faq__col .faq__item:last-child {
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }

  .faq-{{ section.id }} .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    list-style: none;
    cursor: pointer;
    padding: 2.2rem 0;
  }

  .faq-{{ section.id }} .faq__summary::-webkit-details-marker {
    display: none;
  }

  .faq-{{ section.id }} .faq__question {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 2rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
    margin: 0;
  }

  .faq-{{ section.id }} .faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 1.4rem;
    height: 1.4rem;
    margin-top: 0.2rem;
    transition: transform 0.3s ease;
  }

  .faq-{{ section.id }} .faq__icon::before,
  .faq-{{ section.id }} .faq__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: rgb(var(--color-foreground));
    transform: translate(-50%, -50%);
  }

  .faq-{{ section.id }} .faq__icon::before {
    width: 100%;
    height: 0.1rem;
  }

  .faq-{{ section.id }} .faq__icon::after {
    width: 0.1rem;
    height: 100%;
  }

  .faq-{{ section.id }} .faq__item[open] > .faq__summary .faq__icon {
    transform: rotate(45deg);
  }

  .faq-{{ section.id }} .faq__answer {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1.5rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    padding: 0 0 2.4rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="faq-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="faq__title inline-richtext">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- assign half = section.blocks.size | divided_by: 2 -%}

      <faq-accordion>
        <div class="faq__columns">
          <div class="faq__col">
            {%- for block in section.blocks limit: half -%}
              <details
                class="faq__item"
                id="Faq-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <summary class="faq__summary" id="FaqSummary-{{ block.id }}" aria-expanded="false">
                  <h3 class="faq__question">{{ block.settings.question | escape }}</h3>
                  <span class="faq__icon" aria-hidden="true"></span>
                </summary>
                <div
                  class="faq__answer"
                  id="FaqAnswer-{{ block.id }}"
                  role="region"
                  aria-labelledby="FaqSummary-{{ block.id }}"
                >
                  <p>{{ block.settings.answer | newline_to_br }}</p>
                </div>
              </details>
            {%- endfor -%}
          </div>
          <div class="faq__col">
            {%- for block in section.blocks offset: half -%}
              <details
                class="faq__item"
                id="Faq-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <summary class="faq__summary" id="FaqSummary-{{ block.id }}" aria-expanded="false">
                  <h3 class="faq__question">{{ block.settings.question | escape }}</h3>
                  <span class="faq__icon" aria-hidden="true"></span>
                </summary>
                <div
                  class="faq__answer"
                  id="FaqAnswer-{{ block.id }}"
                  role="region"
                  aria-labelledby="FaqSummary-{{ block.id }}"
                >
                  <p>{{ block.settings.answer | newline_to_br }}</p>
                </div>
              </details>
            {%- endfor -%}
          </div>
        </div>
      </faq-accordion>
    </div>
  </div>
</div>

{%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
{%- if faq_blocks.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign faq_count = 0 -%}
      {%- for block in faq_blocks -%}
        {%- if block.settings.question != blank and block.settings.answer != blank -%}
          {%- if faq_count > 0 -%},{%- endif -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | strip_html | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }
          {%- assign faq_count = faq_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

<script>
  if (!customElements.get('faq-accordion')) {
    class FaqAccordion extends HTMLElement {
      constructor() {
        super();
        this.addEventListener('toggle', this.onToggle.bind(this), true);
      }

      onToggle(event) {
        const details = event.target;
        if (!(details instanceof HTMLDetailsElement)) return;

        const summary = details.querySelector('summary');
        if (summary) summary.setAttribute('aria-expanded', details.open);

        if (!details.open) return;

        this.querySelectorAll('details[open]').forEach((openDetails) => {
          if (openDetails === details) return;
          openDetails.removeAttribute('open');
          const openSummary = openDetails.querySelector('summary');
          if (openSummary) openSummary.setAttribute('aria-expanded', 'false');
        });
      }
    }

    customElements.define('faq-accordion', FaqAccordion);
  }
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How long does shipping take?", "answer": "Delivery times vary by region. Orders to the US typically arrive in 7–14 business days. Canada takes 10–16 business days, Australia 12–18 business days, and New Zealand 14–20 business days." } },
        { "type": "faq_item", "settings": { "question": "How much does shipping cost?", "answer": "Shipping is free on all US orders. For Canada, shipping is $5 flat (free over $99). Australia is $9.99 (free over $109), and New Zealand is $12.99 (free over $129)." } },
        { "type": "faq_item", "settings": { "question": "Do you ship internationally?", "answer": "We currently ship to the United States, Canada, Australia, and New Zealand." } },
        { "type": "faq_item", "settings": { "question": "Can I track my order?", "answer": "Yes. You'll receive a tracking link by email once your order has been dispatched." } },
        { "type": "faq_item", "settings": { "question": "Can I change or cancel my order after placing it?", "answer": "We process orders quickly, so changes or cancellations can only be made within 12 hours of purchase. Contact us as soon as possible and we'll do our best to help." } },
        { "type": "faq_item", "settings": { "question": "What is your return policy?", "answer": "We offer a 14-day return window from the date your order is delivered. Items must be unused and in their original packaging to be eligible." } },
        { "type": "faq_item", "settings": { "question": "How do I start a return?", "answer": "Email us with your order number and reason for return. We'll guide you through the next steps." } },
        { "type": "faq_item", "settings": { "question": "Who covers return shipping costs?", "answer": "Return shipping is the customer's responsibility unless the item arrived damaged or incorrect." } },
        { "type": "faq_item", "settings": { "question": "When will I receive my refund?", "answer": "Once we receive and inspect your return, refunds are processed within 5–7 business days back to your original payment method." } },
        { "type": "faq_item", "settings": { "question": "What if my item arrived damaged?", "answer": "We're sorry to hear that. Please contact us within 48 hours of delivery with a photo of the damage and your order number, and we'll make it right." } },
        { "type": "faq_item", "settings": { "question": "Are your products suitable for all sleep positions?", "answer": "Our range covers side sleepers, back sleepers, and those dealing with neck or back tension. Each product page includes guidance on who the product is best suited for." } },
        { "type": "faq_item", "settings": { "question": "What materials are your products made from?", "answer": "We use high-density memory foam and ergonomic-grade materials across our product line. Full material details are listed on each individual product page." } },
        { "type": "faq_item", "settings": { "question": "Do your products come with a warranty?", "answer": "Yes, all SnoozeLab products come with a 6-month quality warranty covering manufacturing defects." } },
        { "type": "faq_item", "settings": { "question": "Do you offer bundles?", "answer": "Yes — we have curated bundles designed around specific needs like neck relief, desk worker comfort, and full-body relaxation. You can find them in our store." } },
        { "type": "faq_item", "settings": { "question": "Can I use a discount code on a bundle?", "answer": "Discount codes cannot be combined with bundle pricing, as bundles are already offered at a reduced rate." } },
        { "type": "faq_item", "settings": { "question": "How do I apply a discount code?", "answer": "Enter your code at checkout in the \"Discount code\" field before completing your purchase." } },
        { "type": "faq_item", "settings": { "question": "How can I contact support?", "answer": "You can reach us by email. We aim to respond within 1–2 business days." } },
        { "type": "faq_item", "settings": { "question": "Do you have a loyalty or rewards program?", "answer": "Not yet — but it's on the roadmap. Stay tuned." } }
      ]
    }
  ]
}
{% endschema %}
