<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap"
  media="print"
  onload="this.media='all'"
>
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap">
</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .faq-{{ section.id }} {
    max-width: 76rem;
    margin: 0 auto;
  }

  .faq-{{ section.id }} .faq__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 3.6rem;
    letter-spacing: 0.01em;
    text-align: center;
    margin: 0 0 4.8rem;
    color: #1A1A1A;
  }

  .faq-{{ section.id }} .faq__item {
    border-top: 0.1rem solid #C8BFB0;
    transition: background-color 0.25s ease;
  }

  .faq-{{ section.id }} .faq__item:last-child {
    border-bottom: 0.1rem solid #C8BFB0;
  }

  .faq-{{ section.id }} .faq__item:hover {
    background-color: #F0EDE8;
  }

  .faq-{{ section.id }} .faq__item[open],
  .faq-{{ section.id }} .faq__item[data-open] {
    background-color: #EDEAE4;
  }

  .faq-{{ section.id }} .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.4rem;
    list-style: none;
    cursor: pointer;
    padding: 2.2rem 2.4rem;
    user-select: none;
  }

  .faq-{{ section.id }} .faq__summary::-webkit-details-marker {
    display: none;
  }

  .faq-{{ section.id }} .faq__question {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 2rem;
    line-height: 1.3;
    letter-spacing: 0.01em;
    margin: 0;
    color: #1A1A1A;
  }

  .faq-{{ section.id }} .faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 1.4rem;
    height: 1.4rem;
    margin-top: 0.2rem;
    transition: transform 0.3s ease;
  }

  .faq-{{ section.id }} .faq__icon::before,
  .faq-{{ section.id }} .faq__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: #1A1A1A;
    transform: translate(-50%, -50%);
    transition: background-color 0.25s ease;
  }

  .faq-{{ section.id }} .faq__icon::before {
    width: 100%;
    height: 0.1rem;
  }

  .faq-{{ section.id }} .faq__icon::after {
    width: 0.1rem;
    height: 100%;
  }

  .faq-{{ section.id }} .faq__item[open] .faq__icon,
  .faq-{{ section.id }} .faq__item[data-open] .faq__icon {
    transform: rotate(45deg);
  }

  .faq-{{ section.id }} .faq__item[open] .faq__icon::before,
  .faq-{{ section.id }} .faq__item[open] .faq__icon::after,
  .faq-{{ section.id }} .faq__item[data-open] .faq__icon::before,
  .faq-{{ section.id }} .faq__item[data-open] .faq__icon::after {
    background-color: #8A9E8C;
  }

  .faq-{{ section.id }} .faq__answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.28s ease;
  }

  .faq-{{ section.id }} .faq__item[data-open] .faq__answer-wrapper {
    grid-template-rows: 1fr;
  }

  .faq-{{ section.id }} .faq__answer-inner {
    overflow: hidden;
  }

  .faq-{{ section.id }} .faq__answer {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.4rem;
    line-height: 1.75;
    color: #444444;
    padding: 0 2.4rem 2.4rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="faq-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="faq__title inline-richtext">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      <faq-accordion>
        {%- for block in section.blocks -%}
          <details
            class="faq__item"
            id="Faq-{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <summary class="faq__summary" id="FaqSummary-{{ block.id }}" aria-expanded="false">
              <h3 class="faq__question">{{ block.settings.question | escape }}</h3>
              <span class="faq__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq__answer-wrapper">
              <div class="faq__answer-inner">
                <div
                  class="faq__answer"
                  id="FaqAnswer-{{ block.id }}"
                  role="region"
                  aria-labelledby="FaqSummary-{{ block.id }}"
                >
                  <p>{{ block.settings.answer | newline_to_br }}</p>
                </div>
              </div>
            </div>
          </details>
        {%- endfor -%}
      </faq-accordion>
    </div>
  </div>
</div>

{%- assign faq_blocks = section.blocks | where: 'type', 'faq_item' -%}
{%- if faq_blocks.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign faq_count = 0 -%}
      {%- for block in faq_blocks -%}
        {%- if block.settings.question != blank and block.settings.answer != blank -%}
          {%- if faq_count > 0 -%},{%- endif -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | strip_html | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | json }}
            }
          }
          {%- assign faq_count = faq_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

<script>
  if (!customElements.get('faq-accordion')) {
    class FaqAccordion extends HTMLElement {
      constructor() {
        super();
        this.addEventListener('click', this.onClick.bind(this), true);
      }

      onClick(event) {
        const summary = event.target.closest('summary.faq__summary');
        if (!summary) return;

        const details = summary.parentElement;
        if (!(details instanceof HTMLDetailsElement)) return;

        event.preventDefault();

        if (details.open) {
          this.closeItem(details);
        } else {
          this.querySelectorAll('details[open]').forEach((d) => {
            if (d !== details) this.closeItem(d);
          });
          this.openItem(details);
        }
      }

      openItem(details) {
        details.open = true;
        details.querySelector('summary').setAttribute('aria-expanded', 'true');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => details.setAttribute('data-open', ''));
        });
      }

      closeItem(details) {
        details.removeAttribute('data-open');
        details.querySelector('summary').setAttribute('aria-expanded', 'false');
        const wrapper = details.querySelector('.faq__answer-wrapper');
        if (wrapper) {
          wrapper.addEventListener(
            'transitionend',
            () => { details.open = false; },
            { once: true }
          );
        } else {
          details.open = false;
        }
      }
    }

    customElements.define('faq-accordion', FaqAccordion);
  }
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How long does shipping take?", "answer": "Delivery times vary by region. Orders to the US typically arrive in 7–14 business days. Canada takes 10–16 business days, Australia 12–18 business days, and New Zealand 14–20 business days." } },
        { "type": "faq_item", "settings": { "question": "How much does shipping cost?", "answer": "Shipping is free on all US orders. For Canada, shipping is $5 flat (free over $99). Australia is $9.99 (free over $109), and New Zealand is $12.99 (free over $129)." } },
        { "type": "faq_item", "settings": { "question": "Do you ship internationally?", "answer": "We currently ship to the United States, Canada, Australia, and New Zealand." } },
        { "type": "faq_item", "settings": { "question": "Can I track my order?", "answer": "Yes. You'll receive a tracking link by email once your order has been dispatched." } },
        { "type": "faq_item", "settings": { "question": "How do I start a return?", "answer": "Email us with your order number and reason for return. We'll guide you through the next steps." } },
        { "type": "faq_item", "settings": { "question": "Who covers return shipping costs?", "answer": "Return shipping is the customer's responsibility unless the item arrived damaged or incorrect." } },
        { "type": "faq_item", "settings": { "question": "When will I receive my refund?", "answer": "Once we receive and inspect your return, refunds are processed within 5–7 business days back to your original payment method." } },
        { "type": "faq_item", "settings": { "question": "What if my item arrived damaged?", "answer": "We're sorry to hear that. Please contact us within 48 hours of delivery with a photo of the damage and your order number, and we'll make it right." } },
        { "type": "faq_item", "settings": { "question": "Are your products suitable for all sleep positions?", "answer": "Our range covers side sleepers, back sleepers, and those dealing with neck or back tension. Each product page includes guidance on who the product is best suited for." } },
        { "type": "faq_item", "settings": { "question": "Do you offer bundles?", "answer": "Yes — we have curated bundles designed around specific needs like neck relief, desk worker comfort, and full-body relaxation. You can find them in our store." } }
      ]
    }
  ]
}
{% endschema %}
