{%- style -%}
  .trust-bar {
    background-color: #E8E4DE;
    margin: 0;
  }

  .trust-bar__viewport {
    overflow: hidden;
  }

  .trust-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    flex: 1 1 0;
  }

  .trust-bar__icon {
    font-size: 1.1em;
    line-height: 1;
  }

  .trust-bar__label {
    font-family: 'Montserrat', var(--font-body-family, sans-serif);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1A1A1A;
    white-space: nowrap;
  }

  .trust-bar__divider {
    width: 1px;
    height: 16px;
    background-color: #C8BFB0;
    flex: 0 0 auto;
  }

  .trust-bar__dot {
    display: none;
  }

  .trust-bar__item--dup {
    display: none;
  }

  @keyframes trust-bar-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 768px) {
    .trust-bar__item {
      opacity: 0;
      animation: trust-bar-fade-in 0.5s ease forwards;
    }

    .trust-bar__item:nth-child(1) {
      animation-delay: 0s;
    }

    .trust-bar__item:nth-child(3) {
      animation-delay: 0.1s;
    }

    .trust-bar__item:nth-child(5) {
      animation-delay: 0.2s;
    }

    .trust-bar__item:nth-child(7) {
      animation-delay: 0.3s;
    }
  }

  @keyframes trust-bar-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 767px) {
    .trust-bar__viewport {
      overflow: hidden;
    }

    .trust-bar__list {
      height: auto;
      flex-wrap: nowrap;
      justify-content: flex-start;
      width: max-content;
      padding: 16px 0;
      animation: trust-bar-scroll 18s linear infinite;
    }

    .trust-bar__viewport:hover .trust-bar__list {
      animation-play-state: paused;
    }

    .trust-bar__item {
      flex: 0 0 auto;
      padding: 0 12px;
      white-space: nowrap;
    }

    .trust-bar__item--dup {
      display: flex;
    }

    .trust-bar__divider {
      display: none;
    }

    .trust-bar__dot {
      display: inline-block;
      margin-left: 0.5em;
      color: #1A1A1A;
    }
  }
{%- endstyle -%}

<div class="trust-bar">
  <div class="trust-bar__viewport">
    <ul class="trust-bar__list" role="list">
      {%- for block in section.blocks -%}
        <li class="trust-bar__item" {{ block.shopify_attributes }}>
          <span class="trust-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <span class="trust-bar__label">{{ block.settings.label }}</span>
          <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
        </li>
        {%- if forloop.last == false -%}
          <li class="trust-bar__divider" aria-hidden="true"></li>
        {%- endif -%}
      {%- endfor -%}
      {%- for block in section.blocks -%}
        <li class="trust-bar__item trust-bar__item--dup" aria-hidden="true">
          <span class="trust-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <span class="trust-bar__label">{{ block.settings.label }}</span>
          <span class="trust-bar__dot" aria-hidden="true">&middot;</span>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
