{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,600&family=Montserrat:wght@300;400;500;600&display=swap');

  /* Dark background — same approach as .cp-cta-banner */
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > div {
    background: #3D3B8E;
  }
  #shopify-section-{{ section.id }} {
    overflow: hidden;
  }

  .section-{{ section.id }}-padding {
    padding-top: 80px;
    padding-bottom: 80px;
    text-align: center;
  }

  /* Heading: lightweight white — mirrors .cp-cta-banner__heading */
  #shopify-section-{{ section.id }} .wpq-header {
    margin-bottom: 3.6rem;
  }
  #shopify-section-{{ section.id }} .wpq-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: normal;
    font-weight: 300;
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1.2;
    margin: 0 0 12px;
    color: #FFFFFF;
  }

  /* Subtitle — mirrors .cp-cta-banner__sub */
  #shopify-section-{{ section.id }} .wpq-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }

  /* 4 equal-width columns desktop */
  #shopify-section-{{ section.id }} .wpq-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 960px;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }

  /* Buttons: solid filled — mirrors .cp-cta-btn */
  #shopify-section-{{ section.id }} .wpq-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    flex: 1;
    padding: 16px 24px;
    border-radius: 0;
    border: 1px solid #E8845A;
    background: #E8845A;
    color: #FFFFFF;
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    white-space: normal;
  }
  #shopify-section-{{ section.id }} .wpq-pill:hover,
  #shopify-section-{{ section.id }} .wpq-pill:focus-visible {
    background: #D4734A;
    border-color: #D4734A;
    color: #FFFFFF;
    outline: none;
  }
  /* Icon field holds the label — hide the separate product title span */
  #shopify-section-{{ section.id }} .wpq-pill span:not(.wpq-pill__icon) {
    display: none;
  }
  #shopify-section-{{ section.id }} .wpq-pill__icon {
    line-height: 1.4;
  }

  /* Tablet: 2×2 grid */
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .wpq-buttons {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
  }

  /* Mobile: single-column stacked */
  @media screen and (max-width: 767px) {
    .section-{{ section.id }}-padding {
      padding-top: 56px;
      padding-bottom: 56px;
    }
    #shopify-section-{{ section.id }} .wpq-buttons {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    #shopify-section-{{ section.id }} .wpq-pill {
      padding: 14px 16px;
    }
  }

  /* Heroicon above each pill */
  #shopify-section-{{ section.id }} .wpq-buttons li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .wpq-icon {
    display: block;
    color: #FFFFFF;
    line-height: 0;
  }
  #shopify-section-{{ section.id }} .wpq-icon svg {
    display: block;
    width: 24px;
    height: 24px;
  }
  #shopify-section-{{ section.id }} .wpq-question {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.75);
    margin: 0;
    min-height: 3em;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="section-{{ section.id }}-padding page-width">

    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="wpq-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="wpq-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="wpq-subtitle{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.subtitle | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="wpq-buttons" role="list">
      {%- for i in (1..4) -%}
        {%- liquid
          case i
            when 1
              assign product      = section.settings.product_1
              assign icon         = section.settings.icon_1
              assign icon_name    = section.settings.icon_name_1
              assign question     = section.settings.question_1
              assign button_label = section.settings.button_label_1
            when 2
              assign product      = section.settings.product_2
              assign icon         = section.settings.icon_2
              assign icon_name    = section.settings.icon_name_2
              assign question     = section.settings.question_2
              assign button_label = section.settings.button_label_2
            when 3
              assign product      = section.settings.product_3
              assign icon         = section.settings.icon_3
              assign icon_name    = section.settings.icon_name_3
              assign question     = section.settings.question_3
              assign button_label = section.settings.button_label_3
            when 4
              assign product      = section.settings.product_4
              assign icon         = section.settings.icon_4
              assign icon_name    = section.settings.icon_name_4
              assign question     = section.settings.question_4
              assign button_label = section.settings.button_label_4
          endcase
        -%}

        {%- if product != blank -%}
          <li>
            {%- if icon_name != blank -%}
              <span class="wpq-icon">
                {%- case icon_name -%}
                  {%- when 'moon' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
                    </svg>
                  {%- when 'arrow-down-circle' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 3 3m0 0 3-3m-3 3v-7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                  {%- when 'arrow-up' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                    </svg>
                  {%- when 'bolt' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                    </svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
            {%- if question != blank -%}
              <p class="wpq-question">{{ question | escape }}</p>
            {%- endif -%}
            <a href="{{ product.url }}" class="wpq-pill">
              <span class="wpq-pill__icon">{{ button_label | default: product.title | escape }}</span>
              <span>{{ product.title | escape }}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

