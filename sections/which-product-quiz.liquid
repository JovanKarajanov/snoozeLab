{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .wpq-header {
    text-align: center;
    margin-bottom: 3.2rem;
  }
  .wpq-header .wpq-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.2;
    margin: 0 0 1rem;
    color: rgb(var(--color-foreground));
  }
  .wpq-header .wpq-subtitle {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.65);
    margin: 0;
  }

  .wpq-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .wpq-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.4rem;
    border-radius: 10rem;
    border: 0.2rem solid #ffffff;
    background: transparent;
    color: #ffffff;
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }
  .wpq-pill:hover,
  .wpq-pill:focus-visible {
    background-color: #C9A96E;
    border-color: #C9A96E;
    color: #1a1a1a;
    outline: none;
  }
  .wpq-pill__icon {
    font-size: 1.6rem;
    line-height: 1;
    flex-shrink: 0;
  }

  /* Mobile: 2-column grid */
  @media screen and (max-width: 749px) {
    .wpq-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .wpq-pill {
      justify-content: center;
      padding: 1rem 1.6rem;
      font-size: 1.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="section-{{ section.id }}-padding page-width">

    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="wpq-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="wpq-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="wpq-subtitle{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.subtitle | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="wpq-buttons" role="list">
      {%- for i in (1..4) -%}
        {%- liquid
          case i
            when 1
              assign product = section.settings.product_1
              assign icon    = section.settings.icon_1
            when 2
              assign product = section.settings.product_2
              assign icon    = section.settings.icon_2
            when 3
              assign product = section.settings.product_3
              assign icon    = section.settings.icon_3
            when 4
              assign product = section.settings.product_4
              assign icon    = section.settings.icon_4
          endcase
        -%}

        {%- if product != blank -%}
          <li>
            <a href="{{ product.url }}" class="wpq-pill">
              {%- if icon != blank -%}
                <span class="wpq-pill__icon" aria-hidden="true">{{ icon }}</span>
              {%- endif -%}
              <span>{{ product.title | escape }}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</div>

{% schema %}
{
  "name": "Which Product Quiz",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Which Product Is Right for You?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Select your concern below to find your perfect match."
    },
    {
      "type": "header",
      "content": "Product 1"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "text",
      "id": "icon_1",
      "label": "Icon / emoji (product 1)",
      "info": "Paste an emoji or short text, e.g. 😣",
      "default": "😣"
    },
    {
      "type": "header",
      "content": "Product 2"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "text",
      "id": "icon_2",
      "label": "Icon / emoji (product 2)",
      "info": "Paste an emoji or short text, e.g. 🦵",
      "default": "🦵"
    },
    {
      "type": "header",
      "content": "Product 3"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "text",
      "id": "icon_3",
      "label": "Icon / emoji (product 3)",
      "info": "Paste an emoji or short text, e.g. 💤",
      "default": "💤"
    },
    {
      "type": "header",
      "content": "Product 4"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "text",
      "id": "icon_4",
      "label": "Icon / emoji (product 4)",
      "info": "Paste an emoji or short text, e.g. 🧠",
      "default": "🧠"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Which Product Quiz"
    }
  ]
}
{% endschema %}
